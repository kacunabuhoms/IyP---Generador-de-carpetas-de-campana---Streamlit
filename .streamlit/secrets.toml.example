app_password = "CAMBIA_ESTA_CONTRASENA"

default_subfolders = ["Fotos", "Totales", "Distribución", "Tipos de Caja", "Acomodo"]

[connections.mysql]
dialect = "mysql"
driver = "pymysql"
host = "TU_HOST_DIGITALOCEAN"
port = 25060
database = "TU_BASE_DE_DATOS"
username = "TU_USUARIO"
password = "TU_PASSWORD"

[gcp_service_account]
type = "service_account"
project_id = "TU_PROJECT_ID"
private_key_id = "TU_PRIVATE_KEY_ID"
private_key = "-----BEGIN PRIVATE KEY-----\nTU_LLAVE\n-----END PRIVATE KEY-----\n"
client_email = "TU_SERVICE_ACCOUNT@TU_PROJECT.iam.gserviceaccount.com"
client_id = "TU_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "TU_CERT_URL"
